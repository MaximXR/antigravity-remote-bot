@echo off
rem ============================================================================
rem Ручной запуск Remoat Telegram-бота (в видимом окне консоли)
rem Manual Startup for Remoat Telegram Bot (in visible console window)
rem 
rem Запускает бота в активном окне командной строки. Позволяет видеть
rem логи работы в реальном времени. В конце добавлена пауза: если бот
rem завершится с ошибкой, окно не закроется автоматически, чтобы вы
rem могли прочитать причину сбоя.
rem 
rem Для остановки бота просто закройте это окно консоли крестиком.
rem ============================================================================

echo [INFO] Starting Remoat Telegram Bot...
call start_ide.bat
node dist/bin/cli.js start
pause
